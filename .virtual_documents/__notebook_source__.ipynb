class SEBlock(nn.Module):
    """Channel attention on mel bins. Stores last batch's weights for inspection."""
    def __init__(self, n_channels, reduction=8):
        super().__init__()
        hidden = max(n_channels // reduction, 4)
        self.fc1 = nn.Linear(n_channels, hidden)
        self.fc2 = nn.Linear(hidden, n_channels)
        self.last_weights = None

    def forward(self, x):
        # x: [B, C, T]
        s = x.mean(dim=2)                       # squeeze: [B, C]
        s = F.relu(self.fc1(s))
        s = torch.sigmoid(self.fc2(s))          # excite: [B, C]
        self.last_weights = s.detach()
        return x * s.unsqueeze(2)               # rescale


class MelCNN(nn.Module):
    def __init__(self, n_mels=N_MELS, hidden=128):
        super().__init__()
        self.se_input = SEBlock(n_mels)
        self.conv1 = nn.Conv1d(n_mels, hidden, kernel_size=5, padding=2)
        self.bn1   = nn.BatchNorm1d(hidden)
        self.conv2 = nn.Conv1d(hidden, hidden, kernel_size=5, padding=2, stride=2)
        self.bn2   = nn.BatchNorm1d(hidden)
        self.conv3 = nn.Conv1d(hidden, hidden * 2, kernel_size=3, padding=1, stride=2)
        self.bn3   = nn.BatchNorm1d(hidden * 2)
        self.pool  = nn.AdaptiveAvgPool1d(1)
        self.dropout = nn.Dropout(0.3)
        self.out_dim = hidden * 2

    def forward(self, mel):
        x = self.se_input(mel)                  # [B, n_mels, T]
        x = F.relu(self.bn1(self.conv1(x)))
        x = F.relu(self.bn2(self.conv2(x)))
        x = F.relu(self.bn3(self.conv3(x)))
        x = self.pool(x).squeeze(-1)            # [B, out_dim]
        return self.dropout(x)


class TextEncoder(nn.Module):
    def __init__(self, model_name=TEXT_MODEL, freeze=True, out_dim=256):
        super().__init__()
        self.bert = AutoModel.from_pretrained(model_name)
        if freeze:
            for p in self.bert.parameters():
                p.requires_grad = False
            self.bert.eval()
        self.proj = nn.Linear(self.bert.config.hidden_size, out_dim)
        self.out_dim = out_dim
        self._frozen = freeze

    def forward(self, input_ids, attention_mask):
        if self._frozen:
            with torch.no_grad():
                out = self.bert(input_ids=input_ids, attention_mask=attention_mask)
        else:
            out = self.bert(input_ids=input_ids, attention_mask=attention_mask)
        cls = out.last_hidden_state[:, 0]       # [B, hidden]
        return self.proj(cls)


class GatedFusion(nn.Module):
    """Per-sample scalar gate. g near 1 → audio-dominant; g near 0 → text-dominant."""
    def __init__(self, audio_dim, text_dim, hidden=256, n_classes=N_CLASSES):
        super().__init__()
        self.audio_proj = nn.Linear(audio_dim, hidden)
        self.text_proj  = nn.Linear(text_dim,  hidden)
        self.gate = nn.Sequential(
            nn.Linear(hidden * 2, hidden),
            nn.ReLU(),
            nn.Dropout(0.2),
            nn.Linear(hidden, 1),
            nn.Sigmoid()
        )
        self.classifier = nn.Sequential(
            nn.Linear(hidden, hidden),
            nn.ReLU(),
            nn.Dropout(0.3),
            nn.Linear(hidden, n_classes)
        )
        self.last_gate = None

    def forward(self, a, t):
        ap = self.audio_proj(a)
        tp = self.text_proj(t)
        g  = self.gate(torch.cat([ap, tp], dim=-1))    # [B, 1]
        self.last_gate = g.detach()
        fused = g * ap + (1 - g) * tp
        return self.classifier(fused)


class SERModel(nn.Module):
    def __init__(self, n_mels=N_MELS, n_classes=N_CLASSES, text_model=TEXT_MODEL):
        super().__init__()
        self.audio  = MelCNN(n_mels=n_mels)
        self.text   = TextEncoder(text_model)
        self.fusion = GatedFusion(self.audio.out_dim, self.text.out_dim,
                                  n_classes=n_classes)

    def forward(self, mel, input_ids, attention_mask):
        a = self.audio(mel)
        t = self.text(input_ids, attention_mask)
        return self.fusion(a, t)


