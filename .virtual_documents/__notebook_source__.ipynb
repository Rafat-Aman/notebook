def parse_emo_evaluation(path):
    rows = []
    with open(path, encoding='utf-8', errors='replace') as f:
        for line in f:
            if line.startswith('['):
                parts = line.strip().split('\t')
                if len(parts) >= 3:
                    utt_id = parts[1].strip()
                    emo    = parts[2].strip()
                    rows.append((utt_id, emo))
    return rows

def parse_transcriptions(path):
    txt = {}
    if not os.path.exists(path): return txt
    with open(path, encoding='latin-1') as f:
        for line in f:
            # Format: 'Ses01F_impro01_F000 [006.2901-008.2357]: Excuse me.'
            m = re.match(r'^(\S+)\s*\[[^\]]*\]\s*:\s*(.*)$', line.strip())
            if m:
                txt[m.group(1).strip()] = m.group(2).strip()
    return txt

def build_iemocap_df(root):
    rows = []
    for sess in range(1, 6):
        sess_path  = f'{root}/Session{sess}'
        emo_dir    = f'{sess_path}/dialog/EmoEvaluation'
        trans_dir  = f'{sess_path}/dialog/transcriptions'
        wav_root   = f'{sess_path}/sentences/wav'
        if not os.path.isdir(emo_dir):
            print(f'  [warn] missing {emo_dir}'); continue

        for emo_file in glob.glob(f'{emo_dir}/*.txt'):
            dialog_id  = os.path.basename(emo_file).replace('.txt', '')
            transcripts = parse_transcriptions(f'{trans_dir}/{dialog_id}.txt')
            for utt_id, emo in parse_emo_evaluation(emo_file):
                wav_path = f'{wav_root}/{dialog_id}/{utt_id}.wav'
                if not os.path.exists(wav_path):
                    continue
                rows.append({
                    'utt_id':   utt_id,
                    'session':  sess,
                    'emotion':  emo,
                    'wav_path': wav_path,
                    'text':     transcripts.get(utt_id, '')
                })
    return pd.DataFrame(rows)

