def apply_class_scheme(df):
    df = df.copy()
    df['label_str'] = df['emotion'].map(EMOTION_MAP)
    df = df.dropna(subset=['label_str'])             # drops fru, fea, dis, sur, oth, xxx
    df = df[df['text'].str.strip().str.len() > 0]    # drop empty transcripts
    df['label'] = df['label_str'].map(LABEL2IDX)
    return df.reset_index(drop=True)

