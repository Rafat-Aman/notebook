    'train': {
        'csv': f'{MELD_BASE}/train/train_sent_emo.csv',
        'audio_dir': f'{MELD_BASE}/train/train_splits',
    },
    'dev': {
        'csv': f'{MELD_BASE}/dev_sent_emo.csv',
        'audio_dir': f'{MELD_BASE}/dev/dev_splits_complete',
    },
    'test': {
        'csv': f'{MELD_BASE}/test_sent_emo.csv',
        'audio_dir': f'{MELD_BASE}/test/output_repeated_splits_test',
    },
}


def build_meld_df(split='train'):

    cfg = MELD_SPLIT_PATHS[split]

    # Load CSV
    raw = pd.read_csv(cfg['csv'])

    print(f'\n=== MELD {split.upper()} ===')
    print(f'rows in csv: {len(raw)}')

    rows = []
    missing_audio = 0

    for _, r in raw.iterrows():

        utt_id = f"dia{r['Dialogue_ID']}_utt{r['Utterance_ID']}"

        # Convert emotion labels
        emo_str = MELD_EMOTION_MAP.get(str(r['Emotion']).lower())

        # Skip unsupported emotions
        if emo_str is None:
            continue

        # Actual audio path
        audio_path = os.path.join(
            cfg['audio_dir'],
            f'{utt_id}.mp4'
        )

        # Skip missing files
        if not os.path.exists(audio_path):
            missing_audio += 1
            continue

        text = str(r['Utterance']).strip()

        # Skip empty text
        if not text:
            continue

        rows.append({
            'utt_id': utt_id,
            'session': -1,
            'emotion': r['Emotion'],
            'label_str': emo_str,
            'label': LABEL2IDX[emo_str],
            'wav_path': audio_path,
            'text': text,
        })

    df = pd.DataFrame(rows)

    print(f'usable rows: {len(df)}')
    print(f'missing audio: {missing_audio}')

    return df


# Build datasets
meld_train = build_meld_df('train')
meld_dev   = build_meld_df('dev')
meld_test  = build_meld_df('test')

# Summary
print('\n=== FINAL COUNTS ===')
print(f'train: {len(meld_train)}')
print(f'dev:   {len(meld_dev)}')
print(f'test:  {len(meld_test)}')

# Label distribution
if len(meld_train):
    print('\nTrain label distribution:')
    print(meld_train['label_str'].value_counts())











