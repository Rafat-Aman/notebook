class IEMOCAPDataset(Dataset):
    def __init__(self, df, tokenizer, sr=SAMPLE_RATE, n_mels=N_MELS, max_sec=MAX_SEC):
        self.df = df.reset_index(drop=True)
        self.tok = tokenizer
        self.sr = sr
        self.max_samples = int(max_sec * sr)
        self.mel = torchaudio.transforms.MelSpectrogram(
            sample_rate=sr, n_fft=N_FFT, hop_length=HOP_LEN, n_mels=n_mels, power=2.0
        )
        self.amp_to_db = torchaudio.transforms.AmplitudeToDB(top_db=80)

    def __len__(self):
        return len(self.df)

    def _load_wav(self, path):
        wav, sr = torchaudio.load(path)
        if sr != self.sr:
            wav = torchaudio.functional.resample(wav, sr, self.sr)
        wav = wav.mean(0)  # mono
        if wav.shape[0] > self.max_samples:
            wav = wav[:self.max_samples]
        else:
            wav = F.pad(wav, (0, self.max_samples - wav.shape[0]))
        return wav

    def __getitem__(self, i):
        row = self.df.iloc[i]
        wav = self._load_wav(row['wav_path'])
        mel = self.amp_to_db(self.mel(wav))                # [n_mels, T]
        mel = (mel - mel.mean()) / (mel.std() + 1e-6)      # per-utterance normalize
        tok = self.tok(row['text'], padding='max_length', truncation=True,
                       max_length=MAX_TEXT_LEN, return_tensors='pt')
        return {
            'mel':            mel,                              # [n_mels, T]
            'input_ids':      tok['input_ids'].squeeze(0),      # [L]
            'attention_mask': tok['attention_mask'].squeeze(0), # [L]
            'label':          torch.tensor(row['label'], dtype=torch.long),
        }

