def get_class_weights(labels, n_classes):
    counts = Counter(labels)
    total = len(labels)
    w = torch.zeros(n_classes)
    for c in range(n_classes):
        w[c] = total / (n_classes * max(counts[c], 1))
    return w


def train_one_epoch(model, loader, opt, criterion):
    model.train()
    if model.text._frozen:
        model.text.bert.eval()      # keep BERT in eval mode (frozen BN/dropout)
    total = 0.0
    for batch in loader:
        opt.zero_grad()
        logits = model(
            batch['mel'].to(device),
            batch['input_ids'].to(device),
            batch['attention_mask'].to(device),
        )
        loss = criterion(logits, batch['label'].to(device))
        loss.backward()
        opt.step()
        total += loss.item()
    return total / len(loader)


@torch.no_grad()
def evaluate(model, loader, collect_attribution=False):
    model.eval()
    preds, trues = [], []
    se_per_class   = {c: [] for c in range(N_CLASSES)}
    gate_per_class = {c: [] for c in range(N_CLASSES)}

    for batch in loader:
        labels = batch['label']
        logits = model(
            batch['mel'].to(device),
            batch['input_ids'].to(device),
            batch['attention_mask'].to(device),
        )
        p = logits.argmax(-1).cpu().numpy()
        t = labels.numpy()
        preds.extend(p); trues.extend(t)

        if collect_attribution:
            se   = model.audio.se_input.last_weights.cpu().numpy()       # [B, n_mels]
            gate = model.fusion.last_gate.cpu().numpy().flatten()        # [B]
            for i, lbl in enumerate(t):
                se_per_class[int(lbl)].append(se[i])
                gate_per_class[int(lbl)].append(float(gate[i]))

    trues = np.array(trues); preds = np.array(preds)
    metrics = {
        'acc':       accuracy_score(trues, preds),
        'macro_f1':  f1_score(trues, preds, average='macro'),
        'wtd_f1':    f1_score(trues, preds, average='weighted'),
    }
    return trues, preds, metrics, se_per_class, gate_per_class






fold_results = []
all_se_per_class   = {c: [] for c in range(N_CLASSES)}    # accumulated across folds
all_gate_per_class = {c: [] for c in range(N_CLASSES)}

for fold_idx, test_session in enumerate(range(1, 6), start=1):
    train_df = df[df['session'] != test_session].reset_index(drop=True)
    test_df  = df[df['session'] == test_session].reset_index(drop=True)
    if SMOKE_TEST:
        train_df = train_df.groupby('label', group_keys=False).head(40).reset_index(drop=True)
        test_df  = test_df.groupby('label',  group_keys=False).head(15).reset_index(drop=True)
    print(f'\n── Fold {fold_idx}  (test = Session {test_session})  '
          f'train={len(train_df)}  test={len(test_df)} ──')

    train_ds = IEMOCAPDataset(train_df, tokenizer)
    test_ds  = IEMOCAPDataset(test_df,  tokenizer)
    train_ld = DataLoader(train_ds, batch_size=BATCH_SIZE, shuffle=True,
                          num_workers=2, pin_memory=True)
    test_ld  = DataLoader(test_ds,  batch_size=BATCH_SIZE, shuffle=False,
                          num_workers=2, pin_memory=True)

    cls_w = get_class_weights(train_df['label'].tolist(), N_CLASSES).to(device)
    print(f'  class weights: {dict(zip(CLASSES, cls_w.cpu().numpy().round(3)))}')

    model = SERModel().to(device)
    opt = torch.optim.AdamW(
        [p for p in model.parameters() if p.requires_grad],
        lr=LR, weight_decay=WEIGHT_DECAY,
    )
    criterion = nn.CrossEntropyLoss(weight=cls_w)

    best_f1 = -1.0
    best_state = None
    for ep in range(1, NUM_EPOCHS + 1):
        loss = train_one_epoch(model, train_ld, opt, criterion)
        _, _, m, _, _ = evaluate(model, test_ld, collect_attribution=False)
        print(f'  ep {ep:02d}  loss={loss:.4f}  acc={m["acc"]:.4f}  '
              f'macroF1={m["macro_f1"]:.4f}')
        if m['macro_f1'] > best_f1:
            best_f1 = m['macro_f1']
            best_state = {k: v.detach().cpu().clone() for k, v in model.state_dict().items()}

    # Reload best epoch and collect attributions on test
    model.load_state_dict(best_state)
    trues, preds, m, se_pc, gate_pc = evaluate(model, test_ld, collect_attribution=True)

    print(f'  [best] acc={m["acc"]:.4f}  macroF1={m["macro_f1"]:.4f}  wtdF1={m["wtd_f1"]:.4f}')
    print(classification_report(trues, preds, target_names=CLASSES, digits=3, zero_division=0))

    fold_results.append({'fold': fold_idx, **m, 'trues': trues, 'preds': preds})
    for c in range(N_CLASSES):
        all_se_per_class[c].extend(se_pc[c])
        all_gate_per_class[c].extend(gate_pc[c])

    del model, best_state
    torch.cuda.empty_cache() if torch.cuda.is_available() else None

